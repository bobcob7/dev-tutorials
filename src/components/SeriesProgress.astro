---
interface Tutorial {
  slug: string;
  title: string;
}

interface Props {
  seriesSlug: string;
  tutorials: Tutorial[];
}
const { seriesSlug, tutorials } = Astro.props;
---

<div class="series-progress-wrap" data-series={seriesSlug} data-tutorials={JSON.stringify(tutorials.map(t => t.slug))}>
  <div class="series-progress-header">
    <div class="progress-bar series-bar">
      <div class="progress-fill" id="series-progress-fill"></div>
    </div>
    <span class="progress-text" id="series-progress-text"></span>
  </div>
  <a href="#" class="continue-btn" id="series-continue-btn" style="display:none">
    Continue where you left off →
  </a>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const wrap = document.querySelector(".series-progress-wrap") as HTMLElement;
    if (!wrap) return;

    const seriesSlug = wrap.dataset.series!;
    const tutorialSlugs: string[] = JSON.parse(wrap.dataset.tutorials!);

    let completedCount = 0;
    let hasAnyProgress = false;

    tutorialSlugs.forEach((slug) => {
      const isComplete = localStorage.getItem(`tutorial-complete:${slug}`);
      if (isComplete) {
        completedCount++;
        hasAnyProgress = true;
      }

      // Check if any steps have been started in this tutorial
      try {
        const raw = localStorage.getItem(`tutorial-progress:${slug}`);
        if (raw) {
          const steps = JSON.parse(raw);
          if (Object.values(steps).some((v) => v === true)) {
            hasAnyProgress = true;
          }
        }
      } catch {}

      // Update the series list item if it exists
      const item = document.querySelector(`.series-item[href="/tutorials/${slug}"]`) as HTMLElement;
      if (item && isComplete) {
        item.classList.add("series-item-done");
      }
    });

    const total = tutorialSlugs.length;
    const pct = total > 0 ? (completedCount / total) * 100 : 0;

    const fill = document.getElementById("series-progress-fill");
    const text = document.getElementById("series-progress-text");
    if (fill) fill.style.width = `${pct}%`;
    if (text) text.textContent = hasAnyProgress
      ? `${completedCount} / ${total} tutorials complete`
      : `${total} tutorials`;

    // Only show continue button if the reader has started at least one step
    const continueBtn = document.getElementById("series-continue-btn") as HTMLAnchorElement;
    if (hasAnyProgress && completedCount < total) {
      const lastVisited = localStorage.getItem(`series-last:${seriesSlug}`);
      const target = lastVisited ?? tutorialSlugs[0];
      const bookmark = localStorage.getItem(`tutorial-bookmark:${target}`) ?? "";
      continueBtn.href = `/tutorials/${target}${bookmark ? "#" + bookmark : ""}`;
      continueBtn.style.display = "inline-flex";
    }
  });
</script>
