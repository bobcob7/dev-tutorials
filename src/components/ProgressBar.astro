---
interface Props {
  tutorialSlug: string;
  seriesSlug?: string;
}
const { tutorialSlug, seriesSlug } = Astro.props;
---

<div class="progress-wrap" data-tutorial={tutorialSlug} data-series={seriesSlug ?? ""}>
  <div class="progress-bar">
    <div class="progress-fill" id="progress-fill"></div>
  </div>
  <span class="progress-text" id="progress-text">0 / 0</span>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const wrap = document.querySelector(".progress-wrap") as HTMLElement;
    if (!wrap) return;

    const slug = wrap.dataset.tutorial!;
    const progressKey = `tutorial-progress:${slug}`;
    const versionKey = `tutorial-version:${slug}`;

    // Find step headings. Series tutorials use h3; standalone use h2.
    const content = document.querySelector(".tutorial-content");
    if (!content) return;

    let stepHeadings = Array.from(content.querySelectorAll("h3[id]")) as HTMLElement[];
    if (stepHeadings.length === 0) {
      stepHeadings = Array.from(content.querySelectorAll("h2[id]")).filter((h) => {
        const text = h.textContent ?? "";
        return /^(Step |Milestone )/i.test(text.trim());
      }) as HTMLElement[];
    }
    if (stepHeadings.length === 0) return;

    // Build the current version fingerprint from step IDs
    const currentStepIds = stepHeadings.map((h) => h.id);
    const currentVersion = currentStepIds.join(",");

    // Load and reconcile progress against current page structure
    function loadProgress(): Record<string, boolean> {
      try {
        const raw = localStorage.getItem(progressKey);
        if (!raw) return {};

        const stored: Record<string, boolean> = JSON.parse(raw);
        const storedVersion = localStorage.getItem(versionKey);

        if (storedVersion === currentVersion) return stored;

        // Version changed — keep progress for step IDs that still exist,
        // drop orphans from renamed/removed steps
        const reconciled: Record<string, boolean> = {};
        for (const id of currentStepIds) {
          if (id in stored) {
            reconciled[id] = stored[id];
          }
        }
        // Save the cleaned-up version
        localStorage.setItem(progressKey, JSON.stringify(reconciled));
        localStorage.setItem(versionKey, currentVersion);
        return reconciled;
      } catch {
        return {};
      }
    }

    function saveProgress(data: Record<string, boolean>) {
      localStorage.setItem(progressKey, JSON.stringify(data));
      localStorage.setItem(versionKey, currentVersion);
    }

    const progress = loadProgress();

    // Add checkboxes to each step heading
    stepHeadings.forEach((heading) => {
      const stepId = heading.id;

      const btn = document.createElement("button");
      btn.className = "step-check";
      btn.setAttribute("aria-label", "Mark step complete");
      btn.dataset.step = stepId;

      if (progress[stepId]) {
        btn.classList.add("checked");
      }

      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const current = loadProgress();
        current[stepId] = !current[stepId];
        saveProgress(current);
        btn.classList.toggle("checked");
        updateBar();
        updateMilestones();
      });

      heading.insertBefore(btn, heading.firstChild);
    });

    // Add milestone markers to h2 headings (only when steps are h3)
    const stepsAreH3 = content.querySelectorAll("h3[id]").length > 0;
    const milestoneHeadings: HTMLElement[] = stepsAreH3
      ? (Array.from(content.querySelectorAll("h2[id]")).filter((h) => {
          const text = h.textContent ?? "";
          return text.includes("Milestone") || text.includes("Step ");
        }) as HTMLElement[])
      : [];

    milestoneHeadings.forEach((heading) => {
      const indicator = document.createElement("span");
      indicator.className = "milestone-indicator";
      heading.appendChild(indicator);
    });

    function getStepsBetweenMilestones(milestoneEl: HTMLElement): string[] {
      const steps: string[] = [];
      let el = milestoneEl.nextElementSibling;
      while (el) {
        if (el.tagName === "H2") break;
        if (el.tagName === "H3" && el.id) {
          steps.push(el.id);
        }
        el = el.nextElementSibling;
      }
      return steps;
    }

    function updateBar() {
      const current = loadProgress();
      const done = currentStepIds.filter((id) => current[id]).length;
      const total = currentStepIds.length;
      const pct = total > 0 ? (done / total) * 100 : 0;

      const fill = document.getElementById("progress-fill");
      const text = document.getElementById("progress-text");
      if (fill) fill.style.width = `${pct}%`;
      if (text) text.textContent = `${done} / ${total} steps`;

      // Store step count and IDs so other pages can compute progress
      // without needing to load the tutorial page
      localStorage.setItem(`tutorial-steps:${slug}`, JSON.stringify(currentStepIds));

      // Store completion timestamp if all done
      if (done === total && total > 0) {
        localStorage.setItem(`tutorial-complete:${slug}`, Date.now().toString());
      } else {
        localStorage.removeItem(`tutorial-complete:${slug}`);
      }

      // Only store bookmark and series-last when at least one step is checked
      if (done > 0) {
        const firstIncomplete = currentStepIds.find((id) => !current[id]);
        const bookmark = firstIncomplete ?? "";
        localStorage.setItem(`tutorial-bookmark:${slug}`, bookmark);

        const series = wrap.dataset.series;
        if (series) {
          localStorage.setItem(`series-last:${series}`, slug);
        }
      }
    }

    function updateMilestones() {
      const current = loadProgress();
      milestoneHeadings.forEach((heading) => {
        const childSteps = getStepsBetweenMilestones(heading);
        const allDone = childSteps.length > 0 && childSteps.every((s) => current[s]);
        const indicator = heading.querySelector(".milestone-indicator");
        if (indicator) {
          indicator.textContent = allDone ? " ✓" : "";
          indicator.classList.toggle("complete", allDone);
        }
      });
    }

    updateBar();
    updateMilestones();
  });
</script>
